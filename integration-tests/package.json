{
  "name": "@tsugit.nvim/integration-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "cy:open": "cypress open --e2e --browser=electron",
    "dev": "concurrently --kill-others --names 'app,cypress' --prefix-colors 'blue,yellow' 'pnpm tui start' 'pnpm cy:open'",
    "lint": "pnpx oxlint --type-aware --deny-warnings --report-unused-disable-directives && eslint --max-warnings=0 ."
  },
  "devDependencies": {
    "@catppuccin/palette": "1.8.0",
    "@tui-sandbox/library": "12.5.3",
    "@types/node": "24.12.2",
    "concurrently": "9.2.1",
    "cypress": "15.14.2",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-oxlint": "1.62.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "tsx": "4.21.0",
    "type-fest": "5.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "wait-on": "9.0.5",
    "zod": "4.4.1"
  }
}
