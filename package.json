    "tui": "pnpm --filter ./integration-tests/ exec tui"
  },
  "devDependencies": {
    "@umbrelladocs/linkspector": "0.4.8",
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2"
