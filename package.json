{
  "name": "@tsugit.nvim/plugin",
  "version": "1.0.0",
  "private": true,
  "description": "Fast lazygit integration for Neovim",
  "keywords": [],
  "license": "MIT",
  "author": "Mika Vilpas",
  "scripts": {
    "cy:run": "pnpm --filter ./integration-tests/ cy:run",
    "dev": "pnpm --filter ./integration-tests/ dev",
    "lint": "pnpm --filter ./integration-tests/ lint",
    "markdownlint": "rumdl check .",
    "prettier": "prettier --check .",
    "tui": "pnpm --filter ./integration-tests/ exec tui"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "cypress",
      "esbuild",
      "node-pty",
      "puppeteer"
    ],
    "ignoredBuiltDependencies": [
      "cypress"
    ]
  }
}
